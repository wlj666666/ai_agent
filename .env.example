# 复制该文件为 .env 并填入真实值；.env 已在 .gitignore 中忽略，不会被提交。
# 应用启动时会自动从项目根目录的 .env 加载这些变量（通过 python-dotenv），
# 且不会覆盖已经在系统/终端环境中设置的同名变量（真实环境变量优先级更高）。

# OpenAI-compatible API configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional tuning
# 单次模型请求的超时时间（秒）；必须是有限正数。
# 零、负数、非数字、NaN 或无穷大都会产生明确配置错误，且不会调用模型 API。
OPENAI_REQUEST_TIMEOUT_SECONDS=60
# 检索最高相关度低于该阈值时会标记为“低置信度”（可能导致 insufficient_info）。
# 必须是 0 到 1 之间（包含两端）的小数；非数字或超出范围会在启动/运行时报出
# 明确的配置错误，不会尝试调用模型 API。
RETRIEVAL_MIN_RELEVANCE=0.15
